# Server
PORT=3950

# SQLite database file (default: ./data/cluster-info.db)
# DATABASE_PATH=./data/cluster-info.db

# Kubernetes / OpenShift connection uses kubeconfig or in-cluster credentials.
# KUBECONFIG=/path/to/kubeconfig

# Namespace containing HelloSpoke CRs on the hub (empty = all namespaces).
# On OCM hubs each spoke cluster typically has its own namespace named after the cluster.
WATCH_NAMESPACE=

# HelloSpoke CRD details (defaults match hellospoke-addon)
CRD_GROUP=example.open-cluster-management.io
CRD_VERSION=v1alpha1
CRD_PLURAL=hellospokes

# Use metadata.name instead of metadata.namespace as the cluster identifier.
# CLUSTER_NAME_FROM=metadata.name

# Optional background polling interval in milliseconds (0 = disabled).
POLL_INTERVAL_MS=0
